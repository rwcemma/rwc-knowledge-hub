  <!-- ═══ TRAINING ═══ -->
  <div id="sub-train" class="sub">
    <p style="font-size:12px;color:var(--ink-muted);margin-bottom:14px;line-height:1.6;">Read each scenario, choose your answer, then reveal the reasoning.</p>
    <div class="sc"><span class="badge b-gray">Scenario 1 — FSA reimbursement</span><div class="sc-q" style="margin-top:10px;">"My FSA provider says the letter needs to include the condition being treated."</div><button class="cbtn cbtn-stop" onclick="rev('r1')">Stop — condition language required = cannot write</button><button class="cbtn cbtn-go" onclick="rev('r1')">Write a modified version without condition language</button><button class="cbtn" onclick="rev('r1')">Ask the client what the plan specifically requires</button><div id="r1" class="sc-rev"><div class="fi fi-amber"><span>★</span><div><strong style="color:#633806;">Best: confirm exact plan requirements first</strong><p style="color:#854f0b;">Some FSA plans use loose language and accept health coach letters. Others genuinely require a code. Find out which before writing or declining.</p></div></div></div></div>
    <div class="sc"><span class="badge b-gray">Scenario 2 — Landlord, mold</span><div class="sc-q" style="margin-top:10px;">"My landlord needs a letter saying I have mold illness so I can break my lease."</div><button class="cbtn cbtn-stop" onclick="rev('r2')">Stop — "mold illness" is a diagnosis</button><button class="cbtn cbtn-go" onclick="rev('r2')">Yes, write as requested</button><button class="cbtn" onclick="rev('r2')">Ask what landlord requires, write modified version</button><div id="r2" class="sc-rev"><div class="fi" style="background:var(--green-light);border:1px solid #9FE1CB;"><span>★</span><div><strong style="color:#085041;">Best: ask what landlord requires, write modified version</strong><p style="color:#085041;">"Mold illness" is a named condition — we cannot write that. But we CAN write a landlord letter using symptom language and testing results.</p></div></div></div></div>
    <div class="sc"><span class="badge b-gray">Scenario 3 — Practitioner input</span><div class="sc-q" style="margin-top:10px;">Practitioner writes: "Sarah has CIRS from mold exposure. The binders help eliminate the mycotoxin load." How do you use this?</div><button class="cbtn" onclick="rev('r3')">Copy verbatim</button><button class="cbtn cbtn-go" onclick="rev('r3')">Translate — remove condition name and clinical framing</button><button class="cbtn" onclick="rev('r3')">Don't include clinical reasoning at all</button><div id="r3" class="sc-rev"><div class="fi" style="background:var(--green-light);border:1px solid #9FE1CB;"><span>★</span><div><strong style="color:#085041;">Correct: translate to compliant language</strong><p style="color:#085041;">"CIRS from mold" → "reported symptoms and testing results attached." "Eliminate mycotoxin load" → "recommended as part of the client's individualized wellness protocols."</p></div></div></div></div>
    <div class="sc"><span class="badge b-gray">Scenario 4 — Pushback</span><div class="sc-q" style="margin-top:10px;">"My FSA admin says they need 'medically necessary' and a diagnosis. Can you update it?"</div><button class="cbtn cbtn-stop" onclick="rev('r4')">Decline — deliver the pushback script</button><button class="cbtn" onclick="rev('r4')">Escalate to Andrea for a middle ground</button><button class="cbtn" onclick="rev('r4')">Rewrite with language that implies medical necessity</button><div id="r4" class="sc-rev"><div class="fi fi-red"><span>✕</span><div><strong style="color:#791F1F;">Correct: decline — no escalation, no rewrite</strong><p style="color:#a32d2d;">Both out of scope. Deliver pushback script. Do not escalate to Andrea for wording — the answer is already no.</p></div></div></div></div>
    <div class="sc"><span class="badge b-gray">Scenario 5 — Signature</span><div class="sc-q" style="margin-top:10px;">Finalizing a health coach track letter for Dr. Bronwyn Morris, D.C. How do you sign it?</div><button class="cbtn" onclick="rev('r5')">Dr. Bronwyn Morris, D.C.</button><button class="cbtn cbtn-go" onclick="rev('r5')">Bronwyn Morris, Health Coach, [Practice Name]</button><button class="cbtn" onclick="rev('r5')">Bronwyn Morris, D.C.</button><div id="r5" class="sc-rev"><div class="fi" style="background:var(--green-light);border:1px solid #9FE1CB;"><span>★</span><div><strong style="color:#085041;">Correct: Bronwyn Morris, Health Coach, [Practice Name]</strong><p style="color:#085041;">No "Dr." prefix, no "D.C." suffix on health coach track. Applies to entire document including letterhead logos.</p></div></div></div></div>
  </div>

  <!-- ═══ QUICK REF ═══ -->
  <div id="sub-qref" class="sub">
    <div class="qr-grid">
      <div class="qr-col qr-green"><div class="qr-label">You may</div><div class="qr-item">Refer to the person as "the client"</div><div class="qr-item">Describe client-reported symptoms (from intake)</div><div class="qr-item">Share general health coach opinions</div><div class="qr-item">Use "recommend," "in my opinion," "I believe"</div><div class="qr-item">Reference testing results in neutral language</div><div class="qr-item">State your role as "health coach"</div><div class="qr-item">Sign with name only — no credentials</div></div>
      <div class="qr-col qr-red"><div class="qr-label">You may not</div><div class="qr-item">Use the word "patient"</div><div class="qr-item">Provide or imply a diagnosis</div><div class="qr-item">Name any medical condition</div><div class="qr-item">Use ICD, CPT, or billing codes</div><div class="qr-item">Use "treatment" (use "recommendation")</div><div class="qr-item">Write "Dr." or credentials (health coach track)</div><div class="qr-item">Complete FMLA or ADA certification forms</div></div>
    </div>
    <div class="card-wrap" style="overflow-x:auto;">
      <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--teal);margin-bottom:10px;">Letter types at a glance</div>
      <table class="ltat"><thead><tr><th>Letter type</th><th>Can we?</th><th>Approval</th><th>Watch-out</th></tr></thead><tbody>
        <tr><td>Landlord accommodation</td><td><span class="badge b-green">Yes</span></td><td><span class="tier t-self" style="font-size:10px;">Self</span></td><td style="color:var(--ink-muted);">No condition names. Testing neutral.</td></tr>
        <tr><td>FSA / HSA reimbursement</td><td><span class="badge b-green">Yes</span></td><td><span class="tier t-self" style="font-size:10px;">Self</span></td><td style="color:var(--ink-muted);">Stop if plan requires codes.</td></tr>
        <tr><td>Christian healthshare</td><td><span class="badge b-amber">Case by case</span></td><td><span class="tier t-mgmt" style="font-size:10px;">Andrea</span></td><td style="color:var(--ink-muted);">Plan requirements vary.</td></tr>
        <tr><td>Supplement necessity</td><td><span class="badge b-green">Yes</span></td><td><span class="tier t-self" style="font-size:10px;">Self</span></td><td style="color:var(--ink-muted);">Wellness support, not treatment.</td></tr>
        <tr><td>Therapy modality</td><td><span class="badge b-green">Yes</span></td><td><span class="tier t-self" style="font-size:10px;">Self</span></td><td style="color:var(--ink-muted);">Include "not a replacement" line.</td></tr>
        <tr><td>General accommodation</td><td><span class="badge b-amber">Limited</span></td><td><span class="tier t-mgmt" style="font-size:10px;">Andrea</span></td><td style="color:var(--ink-muted);">General opinion only.</td></tr>
        <tr><td>Gov't / disability</td><td><span class="badge b-amber">Narrow</span></td><td><span class="tier t-mgmt" style="font-size:10px;">Andrea</span></td><td style="color:var(--ink-muted);">Exact template only.</td></tr>
        <tr><td>FMLA / disability</td><td><span class="badge b-red">No</span></td><td>—</td><td style="color:var(--ink-muted);">Refer to physician.</td></tr>
        <tr><td>FSA w/ diagnosis/codes</td><td><span class="badge b-red">No</span></td><td>—</td><td style="color:var(--ink-muted);">Decline if needed.</td></tr>
        <tr><td>Licensed practitioner</td><td><span class="badge b-blue">Yes — diff. rules</span></td><td><span class="tier t-owner" style="font-size:10px;">Owner</span></td><td style="color:var(--ink-muted);">Practitioner signs w/ credential.</td></tr>
      </tbody></table>
    </div>
  </div>

  <!-- ═══ ESCALATION ═══ -->
  <div id="sub-esc" class="sub">
    <p style="font-size:12px;color:var(--ink-muted);margin-bottom:14px;">Standard letters are self-approved. Andrea only sees true outliers.</p>
    <div class="card-wrap">
      <div class="es"><div class="es-n">1</div><div><strong>Staff runs the decision tree</strong><p>Confirm intake is complete. Hard stop = decline and close.</p></div></div>
      <div class="es"><div class="es-n">2</div><div><strong>Standard letters — self-approve and send</strong><p>Landlord, FSA/HSA, supplement, therapy — draft, review, paste into PB and share.</p></div></div>
      <div class="es"><div class="es-n">3</div><div><strong>Amber flag → flag Andrea</strong><p>Christian healthshare, general accommodation, government, Build Your Own, international. Draft first, flag before sharing.</p></div></div>
      <div class="es"><div class="es-n">4</div><div><strong>Practitioner input → translate → draft</strong><p>Ask why the recommendation benefits this client. Convert to health coach language. No clinical language verbatim.</p></div></div>
      <div class="es"><div class="es-n">5</div><div><strong>Owner review — true edge cases only</strong><p>Legal proceedings, insurance disputes, escalating clients, licensed practitioner track.</p></div></div>
      <div class="es"><div class="es-n">6</div><div><strong>Share in Practice Better</strong><p>Create session note, paste letter body. Make visible, share, save. Message client via PB chat.</p></div></div>
    </div>
    <div style="background:linear-gradient(135deg,var(--ink) 0%,#163a3f 100%);border-radius:12px;padding:18px 22px;margin-top:14px;border:1px solid var(--teal);">
      <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--aqua-light);margin-bottom:10px;">Pushback script — copy and send</div>
      <div id="push-text" style="font-size:13px;color:rgba(255,255,255,.85);line-height:1.85;white-space:pre-wrap;">Hi [Client first name],

I completely understand this isn't the language you were hoping for. This is the best we're able to provide within our legal scope as health coaches — we aren't able to include diagnoses or medical codes in our letters.

If your plan specifically requires that level of documentation, it would need to come from a licensed physician. We're happy to help with anything within our scope.

[Staff name], [Practice name]</div>
      <button class="copy-out" onclick="copyPush()">Copy script</button>
    </div>
  </div>

</div><!-- /main -->

<script>
// ── SUB NAV ──
function showSub(id,el){
  document.querySelectorAll('.sub').forEach(function(p){p.classList.remove('on');});
  document.querySelectorAll('.stab').forEach(function(t){t.classList.remove('on');});
  document.getElementById('sub-'+id).classList.add('on');
  el.classList.add('on');
}

// ── DECISION TREE ──
function ds(id){var el=document.getElementById(id);if(el){el.style.display='block';setTimeout(function(){el.scrollIntoView({behavior:'smooth',block:'nearest'});},60);}}
function dtReset(){
  ['dn-intake','dn2','dn-strict','dn-hardstop','dn-govt','dn-licensed','dn3','dn-pract','dn4','dn-landlord','dn-fsa','dn-therapy','dn-supp','dn-other','dn-lt','dn-ln'].forEach(function(id){var el=document.getElementById(id);if(el)el.style.display='none';});
  document.getElementById('dn1').scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── TEMPLATES ──
function showTmpl(id,el){
  document.querySelectorAll('.tc').forEach(function(t){t.classList.remove('on');});
  document.querySelectorAll('.ttab').forEach(function(t){t.classList.remove('on');});
  var c=document.getElementById('tc-'+id);if(c)c.classList.add('on');
  if(el)el.classList.add('on');
}
function goTmpl(id){
  document.querySelectorAll('.sub').forEach(function(p){p.classList.remove('on');});
  document.querySelectorAll('.stab').forEach(function(t){t.classList.remove('on');});
  document.getElementById('sub-tpl').classList.add('on');
  document.querySelectorAll('.stab')[2].classList.add('on');
  document.querySelectorAll('.tc').forEach(function(t){t.classList.remove('on');});
  document.querySelectorAll('.ttab').forEach(function(t){t.classList.remove('on');});
  var c=document.getElementById('tc-'+id),tb=document.getElementById('tt-'+id);
  if(c)c.classList.add('on');if(tb)tb.classList.add('on');
  setTimeout(function(){document.getElementById('sub-tpl').scrollIntoView({behavior:'smooth'});},80);
}

// ── COPY ──
function copyEl(id){
  var el=document.getElementById(id);if(!el)return;
  navigator.clipboard.writeText(el.innerText||el.textContent).then(function(){
    var btn=event.target;var o=btn.textContent;btn.textContent='Copied!';
    setTimeout(function(){btn.textContent=o;},1800);
  });
}
function copyOut(){
  var t=document.getElementById('out-text').textContent;
  navigator.clipboard.writeText(t).then(function(){
    var b=event.target;var o=b.textContent;b.textContent='Copied!';
    setTimeout(function(){b.textContent=o;},1800);
  });
}
function copyPush(){
  var t=document.getElementById('push-text').textContent;
  navigator.clipboard.writeText(t).then(function(){
    var b=event.target;var o=b.textContent;b.textContent='Copied!';
    setTimeout(function(){b.textContent=o;},1800);
  });
}

// ── TRAINING ──
function rev(id){var el=document.getElementById(id);if(el)el.classList.add('on');}

// ── BUILD YOUR OWN ──
function buildByo(){
  var purpose=document.getElementById('b-purpose').value;
  var symptoms=document.getElementById('b-symptoms').value;
  var rec=document.getElementById('b-rec').value;
  var pract=document.getElementById('b-pract').value||'[PRACTITIONER FULL NAME]';
  var el=document.getElementById('byo-out');
  if(!purpose&&!symptoms&&!rec){el.textContent='Fill in the fields above to generate your letter.';el.style.color='var(--ink-muted)';el.style.fontStyle='italic';return;}
  var sLine=symptoms?'Due to the client\'s reported complaints and symptoms of '+symptoms+', and in my capacity as a health coach,':'Due to the client\'s reported complaints and present symptoms, and in my capacity as a health coach,';
  var rLine=rec?'I believe that '+rec+' would be beneficial to the overall improvement of [CLIENT FIRST NAME]\'s ongoing health-related concerns.':'I believe the recommended wellness support would be beneficial to the overall improvement of [CLIENT FIRST NAME]\'s ongoing health-related concerns.';
  el.textContent='Letter of Necessity\n\nTo whom it may concern,\n\n'+sLine+' '+rLine+'\n\nShould there be any questions, please contact my office directly.\n\n'+pract+'\nHealth Coach, [PRACTICE NAME]';
  el.style.color='var(--ink-soft)';el.style.fontStyle='normal';
}

// ── AI GENERATOR ──
async function generateLetter(){
  var purpose=document.getElementById('g-purpose').value;
  var symptoms=document.getElementById('g-symptoms').value.trim();
  var prac=document.getElementById('g-prac').value.trim();
  var tests=document.getElementById('g-tests').value.trim();
  var supps=document.getElementById('g-supps').value.trim();
  var practice=document.getElementById('g-practice').value;
  if(!purpose||!symptoms||!prac){alert('Please fill in letter purpose, symptoms, and practitioner name.');return;}
  document.getElementById('gen-btn').disabled=true;
  document.getElementById('gen-load').classList.add('on');
  document.getElementById('out-wrap').classList.remove('on');
  var sys='You are a compliance writer for '+practice+', a functional medicine practice. You write Letters of Necessity on behalf of health coaches — not licensed physicians. You must follow these rules with zero exceptions:\n\nIDENTITY: Always sign as "[Full Name], Health Coach" — never Dr., never credentials. Always refer to the person as "the client" — never "the patient." Always write "in my capacity as a health coach" when expressing opinion.\n\nLANGUAGE: Never name a medical condition or diagnosis. Never use ICD or CPT codes. Never use "treatment" — use "recommendation" or "wellness protocol." Never use "prescribed," "ordered," "medically necessary," or "I certify." Always hedge: "I believe," "it is my opinion," "could possibly," "may benefit." Symptoms must come only from what is provided — never invent or infer symptoms.\n\nSTRUCTURE: Start with "To whom it may concern," Reference symptoms as "reported complaints and symptoms of [list]." If testing is provided, reference neutrally. If supplements provided, frame as "recommended as part of the client\'s individualized wellness protocol." End with "Should there be any questions, please contact our office directly." Final line: "[Full Name], Health Coach\\n'+practice+'." Use [CLIENT FIRST NAME] as placeholder.\n\nTONE: Minimalist. Short. No elaboration beyond what is needed. Less is always safer.\n\nFORMAT: Output only the letter body. Start directly with "To whom it may concern,"';
  var msg='Write a Letter of Necessity:\nLetter purpose: '+purpose+'\nClient reported symptoms: '+symptoms+'\nPractitioner name: '+prac+(tests?'\nTesting completed: '+tests:'')+(supps?'\nSupplements recommended: '+supps:'');
  try{
    var resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,system:sys,messages:[{role:'user',content:msg}]})});
    var data=await resp.json();
    var text=data.content&&data.content[0]&&data.content[0].text?data.content[0].text:'Error generating letter. Please try again.';
    document.getElementById('out-text').textContent=text;
    document.getElementById('out-wrap').classList.add('on');
  }catch(e){
    document.getElementById('out-text').textContent='Could not generate letter. Check your connection and try again.';
    document.getElementById('out-wrap').classList.add('on');
  }
  document.getElementById('gen-btn').disabled=false;
  document.getElementById('gen-load').classList.remove('on');
}
</script>
</body>
